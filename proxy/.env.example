# ============================================================================
# Minos Verdict - Proxy Configuration
# ============================================================================

# Backend Detection Service
# -------------------------
# URL of the detection backend API (full path including /detect)
BACKEND_URL=http://127.0.0.1:8000/detect

# Optional bearer token for authentication
BACKEND_AUTH_TOKEN=

# Timeout for backend calls in seconds (increased for OCR processing of images)
BACKEND_TIMEOUT_SECONDS=60

# Proxy Server Configuration
# ---------------------------
PROXY_HOST=127.0.0.1
PROXY_PORT=8080

# Optional client-to-proxy authentication backed by an htpasswd file.
PROXY_AUTH_HTPASSWD_FILE=

# LLM API Interception - Hosts
# -----------------------------
# Comma-separated list of API hosts to intercept for guardrail evaluation.
# The proxy will only analyze requests to these hosts.
#
# Supported providers:
#   - api.openai.com              (OpenAI GPT-4, GPT-4 Vision)
#   - api.anthropic.com           (Anthropic Claude)
#   - api.githubcopilot.com       (GitHub Copilot)
#   - api.groq.com                (Groq)
#   - generativelanguage.googleapis.com  (Google Gemini)
#
# Add custom providers as needed (e.g., azure.openai.com, your-custom-llm-api.com)
INTERCEPTED_HOSTS=api.openai.com,api.anthropic.com,api.githubcopilot.com,api.groq.com,generativelanguage.googleapis.com

# LLM API Interception - Paths
# -----------------------------
# Comma-separated list of API path prefixes to intercept.
# The proxy will only analyze requests that match these path patterns.
#
# Common endpoints:
#   /v1/chat/completions          (OpenAI, Groq, most providers)
#   /v1/completions               (OpenAI legacy)
#   /v1/engines/                  (OpenAI legacy engine-specific)
#   /v1/messages                  (Anthropic Claude)
#   /chat/completions             (GitHub Copilot)
#   /completions                  (Generic completions)
#
# Add custom paths as needed for your LLM provider
INTERCEPTED_PATHS=/v1/chat/completions,/v1/completions,/v1/engines/,/v1/messages,/chat/completions,/completions

# WebSocket Interception - Paths
# ------------------------------
# Comma-separated list of WebSocket path prefixes to intercept.
# If this value is empty, WebSocket interception is disabled.
#
# Examples (provider-specific and illustrative):
#   /v1/realtime
#   /ws
#   /v1/stream
INTERCEPTED_WS_PATHS=/v1/responses

# Minimum risk level to block (low, medium, high)
MIN_BLOCK_LEVEL=low
